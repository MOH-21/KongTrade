# KongTrade environment variables
# Copy to .env and fill in values

# Database (SQLite by default — no server needed)
DATABASE_URL=sqlite+aiosqlite:///./kongtrade.db

# Security (generate your own!)
SECRET_KEY=generate-a-random-secret-here
ENCRYPTION_KEY=generate-another-random-key-here

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
