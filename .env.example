# KongTrade environment variables
# Docker Compose will use these automatically

# Database
POSTGRES_USER=kongtrade
POSTGRES_PASSWORD=kongtrade
POSTGRES_DB=kongtrade
DATABASE_URL=postgresql+asyncpg://kongtrade:kongtrade@db:5432/kongtrade

# Redis
REDIS_URL=redis://redis:6379/0

# Security (change these in production!)
SECRET_KEY=generate-a-random-secret-here
ENCRYPTION_KEY=generate-another-random-key-here

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Postgres port exposed to host (change if 5433 conflicts)
PG_HOST_PORT=5433
REDIS_HOST_PORT=6380
